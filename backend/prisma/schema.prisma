generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model user {
  id         String    @id @default(uuid())
  username   String    @unique
  email      String    @unique
  password   String
  fullname   String
  bio        String?
  university String
  department String
  year       Int
  sessions   Session[]
}

model Session {
  id               String   @id @default(uuid())
  userId           String
  user             user     @relation(fields: [userId], references: [id])
  refreshTokenHash String
  ip               String?
  userAgent        String?
  revoke           Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
}
