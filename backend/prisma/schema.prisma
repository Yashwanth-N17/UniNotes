generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model user {
  id         String      @id @default(uuid())
  username   String      @unique
  email      String      @unique
  password   String
  fullname   String
  bio        String?
  university String
  department String
  year       Int
  semester   Int         @default(1)
  sessions   session[]
  resources  resources[]
  reviews    Review[]
  reports    Report[]
  downloadLogs DownloadLog[]

  stats userStats?
}

model userStats {
  id String @id @default(uuid())

  userId String @unique
  user   user   @relation(fields: [userId], references: [id], onDelete: Cascade)

  totalUploads   Int @default(0)
  totalDownloads Int @default(0)
  totalViews     Int @default(0)
  totalBookmarks Int @default(0)

  averageRating Float @default(0.0)
  totalReviews  Int   @default(0)

  rank         Int      @default(0)
  achievements String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model session {
  id               String   @id @default(uuid())
  userId           String
  user             user     @relation(fields: [userId], references: [id])
  refreshTokenHash String
  ip               String?
  userAgent        String?
  revoke           Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
}

model resources {
  id           String @id @default(uuid())
  title        String
  subject      String
  resourceType String
  description  String
  fileLink     String

  views          Int   @default(0)
  downloads      Int   @default(0)
  averageRating  Float @default(0.0)
  totalReviews   Int   @default(0)
  fileSize       Int?
  pageCount      Int?

  department String
  semester   Int

  userId String
  user   user   @relation(fields: [userId], references: [id])

  reviews      Review[]
  reports      Report[]
  downloadLogs DownloadLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([department, semester])
}

model Review {
  id         String    @id @default(uuid())
  rating     Int       @default(0)
  comment    String?
  resourceId String
  resource   resources @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  userId     String
  user       user      @relation(fields: [userId], references: [id])
  createdAt  DateTime  @default(now())

  @@index([resourceId])
  @@index([userId])
}

model Report {
  id          String   @id @default(uuid())
  reason      String
  description String?
  resourceId  String
  resource    resources @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  userId      String
  user        user      @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())

  @@index([resourceId])
  @@index([userId])
}

model DownloadLog {
  id         String    @id @default(uuid())
  userId     String
  user       user      @relation(fields: [userId], references: [id], onDelete: Cascade)
  resourceId String
  resource   resources @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  ip         String?   
  userAgent  String?   
  createdAt  DateTime  @default(now())

  @@index([userId, resourceId]) 
  @@index([resourceId])         
  @@index([userId])             
}
